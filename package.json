{
  "name": "kuest-auth-worker",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "description": "Kuest API credential generator",
  "repository": {
    "type": "git",
    "url": "https://github.com/kuestcom/auth.git"
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "tsc --noEmit && vite build",
    "knip": "knip --fix --no-config-hints",
    "lint": "eslint . --fix",
    "deploy": "pnpm build && wrangler deploy",
    "preview": "pnpm build && wrangler dev",
    "prepare": "husky"
  },
  "dependencies": {
    "@reown/appkit": "1.8.21",
    "@reown/appkit-adapter-wagmi": "1.8.21",
    "@tanstack/react-query": "5.100.14",
    "lucide-react": "1.21.0",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "viem": "2.53.1",
    "wagmi": "2.19.5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.0.0",
    "@cloudflare/vite-plugin": "1.39.0",
    "@cloudflare/workers-types": "4.20260529.1",
    "@eslint-react/eslint-plugin": "5.8.6",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "24.12.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "10.4.0",
    "eslint-plugin-better-tailwindcss": "4.6.0",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-react-you-might-not-need-an-effect": "1.0.1",
    "husky": "9.1.7",
    "knip": "6.17.1",
    "lint-staged": "17.0.5",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "wrangler": "4.95.0"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
