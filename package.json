{
  "name": "kuest-auth-worker",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "description": "Kuest API credential generator",
  "repository": {
    "type": "git",
    "url": "https://github.com/kuestcom/auth.git"
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "tsc --noEmit && vite build",
    "knip": "knip --fix --no-config-hints",
    "lint": "eslint . --fix",
    "deploy": "pnpm build && wrangler deploy",
    "preview": "pnpm build && wrangler dev",
    "prepare": "husky"
  },
  "dependencies": {
    "@reown/appkit": "1.8.22",
    "@reown/appkit-adapter-wagmi": "1.8.22",
    "@tanstack/react-query": "5.101.2",
    "lucide-react": "1.25.0",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "viem": "2.55.2",
    "wagmi": "2.19.5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.1.0",
    "@cloudflare/vite-plugin": "1.45.1",
    "@cloudflare/workers-types": "5.20260717.1",
    "@eslint-react/eslint-plugin": "5.17.1",
    "@tailwindcss/vite": "4.3.3",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.4.0",
    "eslint-plugin-better-tailwindcss": "4.6.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-react-you-might-not-need-an-effect": "1.0.1",
    "husky": "9.1.7",
    "knip": "6.27.0",
    "lint-staged": "17.0.8",
    "tailwindcss": "4.3.3",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "wrangler": "4.112.0"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
